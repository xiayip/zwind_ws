{
	"version": "2.0.0",
	"tasks": [
	  {
		"label": "colcon: build",
		"type": "shell",
		"command": [
		  "export PATH=$(printf '%s' \"$PATH\" | tr ':' '\\n' | grep -v '^/usr/local/mpi/bin$' | paste -sd ':' -);",
		  "source /opt/ros/jazzy/setup.bash;",
		  "colcon",
		  "build",
		  "--base-paths ${workspaceFolder}",
		  "--symlink-install",
		  "--event-handlers console_cohesion+",
		  "--cmake-args -DCMAKE_BUILD_TYPE=RelWithDebInfo -DCMAKE_EXPORT_COMPILE_COMMANDS=true -DMPI_C_COMPILER=/usr/bin/mpicc.openmpi -DMPI_CXX_COMPILER=/usr/bin/mpicxx.openmpi",
		//   "--packages-select", 
		//   "isaac_ros_segway_rmp"
		//   "segwayrmp",
		//   "segway_msgs"
		],
		"problemMatcher": [],
		"group": {
		  "kind": "build",
		  "isDefault": true
		}
	  },
	  {
		"label": "colcon: clean",
		"type": "shell",
		"command": [
		  "cd ${workspaceFolder};",
		  "rm -rf build;",
		  "rm -rf install;",
		  "rm -rf log;"
		]
	  }
	]
  }